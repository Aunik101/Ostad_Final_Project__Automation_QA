    {
      "name": "NEGATIVE - Login missing password",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 400\", function () {",
              "    pm.response.to.have.status(400);",
              "});",
              "",
              "const jsonData = pm.response.json();",
              "",
              "pm.test(\"response has non-empty error message\", function () {",
              "    pm.expect(jsonData).to.have.property(\"error\");",
              "    pm.expect(jsonData.error).to.be.a(\"string\").and.not.empty;",
              "});",
              "",
              "pm.test(\"error message mentions password\", function () {",
              "    pm.expect(jsonData.error.toLowerCase()).to.include(\"password\");",
              "});"
            ]
          }
        }
