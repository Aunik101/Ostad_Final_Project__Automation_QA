  "item": [
    {
      "name": "Login with registered credentials",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const jsonData = pm.response.json();",
              "",
              "pm.test(\"Response has token\", function () {",
              "    pm.expect(jsonData).to.have.property(\"token\");",
              "    pm.expect(jsonData.token).to.be.a(\"string\").and.not.empty;",
              "});",
              "",
              "pm.collectionVariables.set(\"authToken\", jsonData.token);",
              "pm.collectionVariables.set(\"validLoginEmail\", pm.variables.get(\"loginEmail\"));",
              "pm.collectionVariables.set(\"validLoginPassword\", pm.variables.get(\"loginPassword\"));"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "x-api-key",
            "value": "{{apiKey}}",
            "disabled": false
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "disabled": false
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"email\":\"{{loginEmail}}\",\"password\":\"{{loginPassword}}\"}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "login"
          ]
        },
        "description": "Q3: Login with registered credentials and capture authToken for reuse."
      },
      "response": []
    },
    {
      "name": "GET user by userId",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const jsonData = pm.response.json();",
              "const expectedUserId = String(pm.variables.get(\"userId\"));",
              "const expectedFirstName = pm.variables.get(\"expectedFirstName\");",
              "const expectedLastName = pm.variables.get(\"expectedLastName\");",
              "const expectedEmail = pm.variables.get(\"expectedEmail\");",
              "",
              "pm.test(\"data.id equals userId\", function () {",
              "    pm.expect(String(jsonData.data.id)).to.eql(expectedUserId);",
              "});",
              "",
              "pm.test(\"data.first_name and data.last_name match expected names\", function () {",
              "    pm.expect(jsonData.data.first_name).to.eql(expectedFirstName);",
              "    pm.expect(jsonData.data.last_name).to.eql(expectedLastName);",
              "});",
              "",
              "pm.test(\"data.email matches expected email\", function () {",
              "    pm.expect(jsonData.data.email).to.eql(expectedEmail);",
              "});",
              "",
              "pm.collectionVariables.set(\"fetchedUserId\", String(jsonData.data.id));",
              "pm.collectionVariables.set(\"fetchedFirstName\", jsonData.data.first_name);",
              "pm.collectionVariables.set(\"fetchedLastName\", jsonData.data.last_name);",
              "pm.collectionVariables.set(\"fetchedEmail\", jsonData.data.email);",
              "pm.collectionVariables.set(\"fetchedAvatar\", jsonData.data.avatar || \"\");"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "x-api-key",
            "value": "{{apiKey}}",
            "disabled": false
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/users/{{userId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "users",
            "{{userId}}"
          ]
        },
        "description": "Q4: Get user by userId and verify returned user fields match expected values."
      },
      "response": []
    },
    {
      "name": "PUT Updated profile",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const jsonData = pm.response.json();",
              "const expectedName = pm.variables.get(\"putName\");",
              "const expectedJob = pm.variables.get(\"putJob\");",
              "",
              "pm.test(\"response name/job echo request\", function () {",
              "    pm.expect(jsonData.name).to.eql(expectedName);",
              "    pm.expect(jsonData.job).to.eql(expectedJob);",
              "});",
              "",
              "pm.test(\"updatedAt exists and is valid ISO timestamp\", function () {",
              "    pm.expect(jsonData).to.have.property(\"updatedAt\");",
              "    pm.expect(new Date(jsonData.updatedAt).toISOString()).to.eql(jsonData.updatedAt);",
              "});",
              "",
              "pm.collectionVariables.set(\"lastPutName\", jsonData.name);",
              "pm.collectionVariables.set(\"lastPutJob\", jsonData.job);",
              "pm.collectionVariables.set(\"lastPutUpdatedAt\", jsonData.updatedAt);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "x-api-key",
            "value": "{{apiKey}}",
            "disabled": false
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "disabled": false
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"name\":\"{{putName}}\",\"job\":\"{{putJob}}\"}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/users/{{userId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "users",
            "{{userId}}"
          ]
        },
        "description": "Q5: Update the full profile and verify echo fields and updatedAt timestamp."
      },
      "response": []
    },
